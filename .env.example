# Public browser configuration. These values are safe to expose only because RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Existing GitHub Pages static export support.
NEXT_PUBLIC_BASE_PATH=

# Never add sb_secret_* or legacy service_role keys to NEXT_PUBLIC_* variables.
